# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/irctc_hygiene

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Primary frontend URL (required on Render)
CLIENT_URL=https://irctc-hygiene-monitoring-system.vercel.app
# Additional allowed origins, comma-separated (optional)
EXTRA_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/irctc_hygiene

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# ── Admin Account ─────────────────────────────────────────────────────────────
# These are used by the seed script to create the admin account.
# Change them before running: npm run seed
ADMIN_EMAIL=admin@irctc.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Admin

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
